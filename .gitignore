.DS_Store
**/.DS_Store

# Third-party raw archives are not redistributed via GitHub.
data/raw/

# Local staged review-freeze copies are distributed as release assets instead.
submission/frozen-package/

# GitHub hard file-size cap: keep oversized processed CSVs in the release asset.
data/processed/service_cohort_broad_v2018.csv
data/processed/service_cohort_top2_filtered_partial_v2018.csv
data/processed/service_cohort_top3_filtered_container_usage.csv

# Python cache noise.
**/__pycache__/
**/*.pyc

# Transient LaTeX build outputs.
manuscript/*.aux
manuscript/*.bbl
manuscript/*.blg
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.log
manuscript/*.out
manuscript/*.synctex.gz

# Revision response LaTeX intermediates.
revisions/*.aux
revisions/*.fdb_latexmk
revisions/*.fls
revisions/*.log
revisions/*.out

# Local submission staging and visual QA exports.
submission/source-package/
submission/qa-pages/

# Large per-timestep experiment traces are retained locally or as release assets,
# not in normal Git history.
experiments/results/**/full_ua_mstcn_*_predictions.csv
experiments/results/**/full_ua_mstcn_*_policy_series.csv
experiments/results/**/service_qlr_predictions.csv
experiments/results/**/service_qlr_policy_series.csv
experiments/results/**/aggregate_qlr_predictions.csv
experiments/results/qlr_aggregate_full/aggregate_qlr_policy_series.csv
experiments/results/**/*_run_logs/
experiments/results/**/stdout.log
experiments/results/**/stderr.log
experiments/results/**/pid.txt
